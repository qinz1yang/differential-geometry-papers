# Ignore everything by default
*
# Allow directories to be traversed
!*/

# Allow specific files in any directory
!*.lean
!README.md
!readme.md
!lakefile.toml
!lakefile.lean

# Allow essential files at root
!/.gitignore
!/lean-toolchain

# Explicitly re-ignore build directories & macOS clutter
.lake/
**/.lake/
.DS_Store
**/.DS_Store